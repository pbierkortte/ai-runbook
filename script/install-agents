#!/bin/bash
# install-agents
# Installs AI agents when credentials are available.

# Install Cline if OPENROUTER_API_KEY is set
if [ -n "${OPENROUTER_API_KEY:-}" ]; then
  npm i -g cline
  cline auth -p openrouter -k "$OPENROUTER_API_KEY" -m openrouter/auto
fi

# Install Claude Code if either auth method is available
if [ -n "${ANTHROPIC_API_KEY:-}" ] || [ -n "${CLAUDE_CODE_OAUTH_REFRESH_TOKEN:-}" ]; then
  curl -fsSL https://claude.ai/install.sh | bash
fi

# Refresh token auth: requires scopes and an explicit login to exchange the token
if [ -n "${CLAUDE_CODE_OAUTH_REFRESH_TOKEN:-}" ] && [ -z "${ANTHROPIC_API_KEY:-}" ]; then
  if [ -z "${CLAUDE_CODE_OAUTH_SCOPES:-}" ]; then
    echo "Error: CLAUDE_CODE_OAUTH_SCOPES is required with CLAUDE_CODE_OAUTH_REFRESH_TOKEN" >&2
    echo "See docs/claude-code-codespaces-auth.md for setup" >&2
    exit 1
  fi
  claude auth login
fi
