#!/usr/bin/env bash
# split-manifest
# Reads agents/openskills-manifest.yml and writes per-skill .openskills.json files.
# Creates skill directories as needed.

set -euo pipefail
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
cd "$(dirname "$SCRIPT_PATH")/.."

[[ -z "${MANIFEST:-}" ]] && { echo "warning: MANIFEST not set, skipping" >&2; exit 0; }

for dir in $(yq '.[].source' "$MANIFEST"); do
  mkdir -p "$dir"
  yq -o=json ".[] | select(.source == \"$dir\")" "$MANIFEST" > "$dir/.openskills.json"
  touch "$dir/SKILL.md"
done
