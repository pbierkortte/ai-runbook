#!/bin/bash
set -euo pipefail

[[ -f .git/info/attributes ]] && sed -i '/^AGENTS\.md filter=agents$/d' .git/info/attributes
[[ -f .git/info/exclude ]] && sed -i '/^\*_PROTOCOL\.md$/d' .git/info/exclude
git config --unset filter.agents.clean 2>/dev/null || true
git config --unset filter.agents.smudge 2>/dev/null || true

[[ "${GIT_EDITOR:-}" == "nano" ]] && unset GIT_EDITOR || true
[[ "${GIT_PAGER:-}" == "cat" ]] && unset GIT_PAGER || true
