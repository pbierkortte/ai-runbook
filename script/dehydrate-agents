#!/bin/bash
set -eo pipefail
shopt -s globstar nullglob

for f in **/AGENTS.md; do
  [[ -L "$f" ]] && continue
  echo '<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->' > "$f"
done

for f in **/MANIFEST.md; do
  [[ -L "$f" ]] && continue
  echo '<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->' > "$f"
done
