#!/bin/bash
# dehydrate-agents
#
# Strips AGENTS.md files back to stub headers for clean commits.
# Reverse of hydrate-agents which expands them with heading indexes.
#
# Usage: bash script/dehydrate-agents

set -euo pipefail

shopt -s globstar nullglob

for f in **/AGENTS.md; do
  [ -L "$f" ] && continue
  echo '<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->' > "$f"
done
