#!/bin/bash
set -eo pipefail

if [[ -n "${CLINE_CODE_ENABLE:-}" ]]; then
  export CLINE_OTEL_TELEMETRY_ENABLED=false
  npm install -g cline
  mkdir -p "$HOME/.cline/data"
  cat > "$HOME/.cline/data/globalState.json" <<'EOF'
{
  "apiProvider": "openrouter",
  "apiModelId": "~anthropic/claude-sonnet-latest"
}
EOF
  cline auth -p openrouter -k "$OPENROUTER_API_KEY" -m "~anthropic/claude-sonnet-latest" -m "~anthropic/claude-sonnet-latest"
fi
