#!/bin/bash
# setup-skills
# Creates a shared skills directory and symlinks it into each agent.
#
# Canonical location: ~/.agent/skills
# ~/.agents/skills -> ~/.agent/skills
# ~/.cline/skills  -> ~/.agent/skills
# ~/.claude/skills -> ~/.agent/skills

set -euo pipefail

# Canonical skills dir
mkdir -p "$HOME/.agent/skills"

# ~/.agents: real dir with skills symlink pointing at canonical
mkdir -p "$HOME/.agents"
rm -f "$HOME/.agents/skills"
ln -s "$HOME/.agent/skills" "$HOME/.agents/skills"

# Cline: direct symlink to canonical
mkdir -p "$HOME/.cline"
rm -f "$HOME/.cline/skills"
ln -s "$HOME/.agent/skills" "$HOME/.cline/skills"

# Claude Code: direct symlink to canonical
mkdir -p "$HOME/.claude"
rm -f "$HOME/.claude/skills"
ln -s "$HOME/.agent/skills" "$HOME/.claude/skills"
