#!/bin/bash
set -eo pipefail
export PATH="$HOME/.local/bin:$PATH"

out='# generated DO NOT EDIT!'
out+=$'\n'"$(find skills -name SKILL.md -printf '%h\n' | sort |
  jq -R '{source: ., sourceType: "local", localPath: .}' |
  jq -s '.' | yq -P -p=json '.')"
echo "$out" > agents/openskills-manifest.yml
