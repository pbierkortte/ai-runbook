#!/bin/bash
# bootstrap
# Sets up an AI-friendly dev environment.
# Installs tools, configures shells, and wires up skill dirs.
#
# Usage: bash script/bootstrap

set -euo pipefail

DIR="$(realpath "${BASH_SOURCE%/*}")"

cd "$DIR"

source env-vars
source setup-git
source setup-skills
source install-deps
source install-agents
source openskills-manifest
source stage-protocols
source hydrate-agents
source shell-hooks
