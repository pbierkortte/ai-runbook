#!/bin/bash
# bootstrap
#
# Sets up an AI-friendly dev environment.
# Installs tools, configures shells, and wires up skill dirs.
#
# Usage: bash script/bootstrap

set -euo pipefail

# Dependencies
# Install yq if missing (also in openskills-manifest.sh for standalone use)

_bindir="${HOME}/.local/bin"
mkdir -p "$_bindir"
if [[ ! -f "${_bindir}/yq" ]]; then
  _os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  _arch="$(uname -m)"
  case "$_os" in
    linux*)           _os="linux"   ;;
    darwin*)          _os="darwin"  ;;
    mingw*|msys*|cygwin*) _os="windows" ;;
  esac
  case "$_arch" in
    x86_64|amd64) _arch="amd64" ;;
    arm64|aarch64) _arch="arm64" ;;
  esac
  _bin="${_bindir}/yq"
  _url="https://github.com/mikefarah/yq/releases/latest/download/yq_${_os}_${_arch}"
  [[ "$_os" == "windows" ]] && { _bin="${_bindir}/yq.exe"; _url="${_url}.exe"; }
  wget "$_url" -O "$_bin"
  chmod +x "$_bin"
fi
export PATH="$_bindir:$PATH"

# AI-friendly environment defaults
# Suppress pagers and noisy output so agents parse stdout cleanly

# Git: disable pager and use a simple editor
command -v git &>/dev/null && export GIT_PAGER=cat GIT_EDITOR="nano"

# Python: silence pip and skip .pyc to keep logs clean
command -v pip &>/dev/null && export PIP_QUIET=1 PYTHONDONTWRITEBYTECODE=1

# npm: reduce log noise so agents focus on errors
command -v npm &>/dev/null && export NPM_CONFIG_LOGLEVEL=warn

# Hook collate into shell startup so agents always see fresh indexes
COLLATE="$(cd "$(dirname "$0")" && pwd)/agents-collate.sh"
LINE="[ -f \"$COLLATE\" ] && bash \"$COLLATE\""

for rc in ~/.bashrc ~/.bash_profile ~/.zshrc ~/.zprofile; do
  grep -qsF "$LINE" "$rc" || echo "$LINE" >> "$rc"
done

# BASH_ENV makes non-interactive bash source .bashrc for collate to run
BASH_ENV_LINE='export BASH_ENV="$HOME/.bashrc"'
for rc in ~/.bashrc ~/.bash_profile; do
  grep -qsF "$BASH_ENV_LINE" "$rc" || echo "$BASH_ENV_LINE" >> "$rc"
done

# In Codespaces, point the manifest at the dotfiles copy
_dotfiles_dir="/workspaces/.codespaces/.persistedshare/dotfiles"
if [[ -f "$_dotfiles_dir/agents/openskills-manifest.yml" ]]; then
  export OPENSKILLS_MANIFEST_PATH="$_dotfiles_dir/agents/openskills-manifest.yml"
fi

# Run the OpenSkills manifest to install per-skill metadata
OPENSKILLS="$(cd "$(dirname "$0")" && pwd)/openskills-manifest.sh"
[ -f "$OPENSKILLS" ] && bash "$OPENSKILLS"

# Skills
# One shared dir symlinked into each agent so all see the same skills

## Global
mkdir -p "$HOME/.agents/skills"

## Cline
mkdir -p "$HOME/.cline"
rm -f "$HOME/.cline/skills"
ln -s "$HOME/.agents/skills" "$HOME/.cline/skills"

## Claude
mkdir -p "$HOME/.claude"
rm -f "$HOME/.claude/skills"
ln -s "$HOME/.agents/skills" "$HOME/.claude/skills"

# Agents

# Install Cline if OPENROUTER_API_KEY is set
if [ -n "${OPENROUTER_API_KEY:-}" ]; then
  npm i -g cline
  cline auth -p openrouter -k "$OPENROUTER_API_KEY" -m openrouter/auto
fi

# Install Claude Code if either auth method is available
if [ -n "${ANTHROPIC_API_KEY:-}" ] || [ -n "${CLAUDE_CODE_OAUTH_REFRESH_TOKEN:-}" ]; then
  curl -fsSL https://claude.ai/install.sh | bash
fi

# Refresh token auth: requires scopes and an explicit login to exchange the token
if [ -n "${CLAUDE_CODE_OAUTH_REFRESH_TOKEN:-}" ] && [ -z "${ANTHROPIC_API_KEY:-}" ]; then
  if [ -z "${CLAUDE_CODE_OAUTH_SCOPES:-}" ]; then
    echo "Error: CLAUDE_CODE_OAUTH_SCOPES is required with CLAUDE_CODE_OAUTH_REFRESH_TOKEN" >&2
    echo "See docs/claude-code-codespaces-auth.md for setup" >&2
    exit 1
  fi
  claude auth login
fi
