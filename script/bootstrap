#!/bin/bash
# bootstrap
# Sets up an AI-friendly dev environment.
# Installs tools, configures shells, and wires up skill dirs.
#
# Usage: bash script/bootstrap

set -euo pipefail

DIR="$(realpath "$(dirname "${BASH_SOURCE[0]}")")"

cd "$DIR"

source env-vars
source setup-git
source setup-skills
source install-deps
source install-agents
cd "$DIR" && source openskills-manifest
cd "$DIR" && source stage-protocols
cd "$DIR" && source hydrate-agents
cd "$DIR" && source shell-hooks
