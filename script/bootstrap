#!/bin/bash
# bootstrap
# Sets up an AI-friendly dev environment.
# Installs tools, configures shells, and wires up skill dirs.
#
# Usage: bash script/bootstrap

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/set-env"
source "$SCRIPT_DIR/setup-git"
source "$SCRIPT_DIR/setup-skills"
source "$SCRIPT_DIR/install-deps"
source "$SCRIPT_DIR/install-agents"
source "$SCRIPT_DIR/install-skills"
source "$SCRIPT_DIR/stage-protocols"
source "$SCRIPT_DIR/hydrate-agents"
source "$SCRIPT_DIR/install-hooks"
