#!/bin/bash
# stage-protocols
#
# Stages protocol files into the target workspace root.
#
# Scans protocols/*/PROTOCOL.md and copies each to root as <dirname>_PROTOCOLS.md.
# Gitignore keeps staged files out of commits.
# Collate indexes them into AGENTS.md so agents see everything.
#
# Sidecar mode (running from a dotfiles clone):
#   - Stages protocols into the target workspace.
#   - Works for any repo name.
#   - Silently skips if no protocols exist.
#
# Self mode (running inside the sidecar repo itself):
#   - Stages protocols into the project root.
#   - Detected when the target workspace has a protocols/ directory.

set -euo pipefail
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"

DOTFILES_PROTOCOLS_DIR="$(dirname "$SCRIPT_PATH")/../protocols"
mkdir -p "$DOTFILES_PROTOCOLS_DIR"
DOTFILES_PROTOCOLS_DIR="$(readlink -f "$DOTFILES_PROTOCOLS_DIR")"

# Determine the target workspace
# Default: derive repo root from script location
# Override: GITHUB_REPOSITORY env var points to the workspace
REPO_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
if [[ -n "${GITHUB_REPOSITORY:-}" ]] && [[ -d "$(dirname "$REPO_ROOT")/$(basename "$GITHUB_REPOSITORY")" ]]; then
  TARGET="$(dirname "$REPO_ROOT")/$(basename "$GITHUB_REPOSITORY")"
else
  TARGET="$REPO_ROOT"
fi

REPO_NAME="$(basename "$TARGET")"
PROTOCOLS_DIR="$TARGET/protocols"

rm -f "$TARGET/.protocols"
ln -s "$DOTFILES_PROTOCOLS_DIR" "$TARGET/.protocols"

staged=0

# .protocols/ → dot name
for proto in "$DOTFILES_PROTOCOLS_DIR"/*/PROTOCOL.md; do
  [[ -f "$proto" ]] || continue
  dirname="$(basename "$(dirname "$proto")")"
  upper="${dirname^^}"
  cp "$proto" "$TARGET/.${upper}_PROTOCOLS.md"
  staged=$((staged + 1))
done

# protocols/ → no dot name
for proto in "$PROTOCOLS_DIR"/*/PROTOCOL.md; do
  [[ -f "$proto" ]] || continue
  dirname="$(basename "$(dirname "$proto")")"
  upper="${dirname^^}"
  cp "$proto" "$TARGET/${upper}_PROTOCOLS.md"
  staged=$((staged + 1))
done

if [[ "$staged" -gt 0 ]]; then
  echo "stage-protocols: staged $staged protocol(s) to $REPO_NAME"
fi


