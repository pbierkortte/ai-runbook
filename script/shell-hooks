#!/bin/bash
# shell-hooks
# Hooks hydrate-agents into shell startup so agents always see fresh indexes.

DIR="$(realpath "${BASH_SOURCE%/*}")"
HYDRATE="$DIR/hydrate-agents"
LINE="[ -f \"$HYDRATE\" ] && bash \"$HYDRATE\""

for rc in ~/.bashrc ~/.bash_profile ~/.zshrc ~/.zprofile; do
  grep -qsF "$LINE" "$rc" || echo "$LINE" >> "$rc"
done

# BASH_ENV makes non-interactive bash source .bashrc so hydrate-agents runs
BASH_ENV_LINE='export BASH_ENV="$HOME/.bashrc"'
for rc in ~/.bashrc ~/.bash_profile; do
  grep -qsF "$BASH_ENV_LINE" "$rc" || echo "$BASH_ENV_LINE" >> "$rc"
done
