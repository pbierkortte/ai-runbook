#!/bin/bash
set -euo pipefail
shopt -s nullglob

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
DOTFILES_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel)"
DOTFILES_PERSISTED_DIR="$(cd "$DOTFILES_ROOT/.." && pwd)/dotfiles"

for proto in "$DOTFILES_ROOT"/protocols/*/PROTOCOL.md "$DOTFILES_PERSISTED_DIR"/protocols/*/PROTOCOL.md; do
  [[ -f "$proto" ]] || continue
  name="$(basename "$(dirname "$proto")")"
  if [[ "$proto" == *"$DOTFILES_PERSISTED_DIR"* ]]; then
    prefix='DOT_'
  else
    prefix=''
  fi
  rm -f "$REPO_ROOT/${prefix}${name^^}_PROTOCOL.md"
done
