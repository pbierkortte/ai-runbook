#!/bin/bash
set -eo pipefail
shopt -s nullglob

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"

DOTFILES_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
DOTFILES_REPO_NAME="ai-runbook"

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0 2>/dev/null || exit 0

REPO_ROOT="$(git rev-parse --show-toplevel)"
REPO_NAME=$(basename "$REPO_ROOT")

[[ -d "$REPO_ROOT/rules" || -d "$DOTFILES_ROOT/rules" ]] || return 0 2>/dev/null || exit 0

rm -f "$REPO_ROOT"/*_RULES.md

for proto in "$REPO_ROOT"/rules/*/RULE.md; do
  [[ -f "$proto" ]] || continue
  name="$(basename "$(dirname "$proto")")"
  cp "$proto" "$REPO_ROOT/${name^^}_RULES.md"
done

if [[ "$REPO_NAME" != "$DOTFILES_REPO_NAME" ]]; then
  for proto in "$DOTFILES_ROOT"/rules/*/RULE.md; do
    [[ -f "$proto" ]] || continue
    name="$(basename "$(dirname "$proto")")"
    cp "$proto" "$REPO_ROOT/DOT_${name^^}_RULES.md"
  done
fi
