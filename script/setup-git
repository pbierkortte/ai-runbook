#!/bin/bash
# setup-git
# Configures git info for AI agent repos.
# Filter assignment lives in .git/info/attributes.
# Filter definition lives in .git/config.
# Protocol exclusion lives in .git/info/exclude.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Configure git info for agent-enabled repos
if [ -f "$REPO_ROOT/AGENTS.md" ]; then
  grep -qsF 'AGENTS.md filter=agents' "$REPO_ROOT/.git/info/attributes" || echo 'AGENTS.md filter=agents' >> "$REPO_ROOT/.git/info/attributes"
  grep -qsF '*_PROTOCOL.md' "$REPO_ROOT/.git/info/exclude" || echo '*_PROTOCOL.md' >> "$REPO_ROOT/.git/info/exclude"
  git -C "$REPO_ROOT" config filter.agents.clean 'echo "<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->"'
  git -C "$REPO_ROOT" config filter.agents.smudge cat
fi
