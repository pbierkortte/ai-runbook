#!/bin/bash
# install-agents-filter
# Configures the git clean/smudge filter for AGENTS.md files.
# Clean replaces content with a stub header on commit.
# Smudge passes through stored content on checkout.

set -euo pipefail

git config filter.agents.clean 'echo "<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->"'
git config filter.agents.smudge cat
