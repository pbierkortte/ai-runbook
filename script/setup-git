#!/bin/bash
# setup-git
# Configures git info for AI agent repos.
# Filter assignment lives in .git/info/attributes.
# Filter definition lives in .git/config.
# Protocol exclusion lives in .git/info/exclude.

set -euo pipefail

TARGET="$(pwd)"

# Configure git info for agent-enabled repos
if [ -f "$TARGET/AGENTS.md" ]; then
  grep -qsF 'AGENTS.md filter=agents' "$TARGET/.git/info/attributes" || echo 'AGENTS.md filter=agents' >> "$TARGET/.git/info/attributes"
  grep -qsF '*_PROTOCOL.md' "$TARGET/.git/info/exclude" || echo '*_PROTOCOL.md' >> "$TARGET/.git/info/exclude"
  git -C "$TARGET" config filter.agents.clean 'echo "<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->"'
  git -C "$TARGET" config filter.agents.smudge cat
fi
