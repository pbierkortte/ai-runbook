#!/bin/bash
set -eo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
DOTFILES_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

cat > ~/.dotfilesrc <<EOF
#!/bin/bash
source "$DOTFILES_ROOT/script/stage-rules"
source "$DOTFILES_ROOT/script/hydrate-manifest"
source "$DOTFILES_ROOT/script/hydrate-agents"
source "$DOTFILES_ROOT/script/configure-git"
EOF

chmod +x ~/.dotfilesrc
