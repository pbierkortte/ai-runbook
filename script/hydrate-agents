#!/bin/bash
# hydrate-agents
#
# A Card Catalog for AI Agents
#
# Scans markdown headings and writes a heading-based table of contents into each AGENTS.md found from where you run it.
# Any AI agent reads the catalog, knows what exists, and drills into the full doc on demand.
#
# Scales to 1000s of docs with no context overhead and no special dbs.
# No vector DB, no embeddings, just this script.
#
# Usage: bash script/hydrate-agents

set -euo pipefail

DIR="$(realpath "$(dirname "${BASH_SOURCE[0]}")")"
cd "$DIR/.."

shopt -s globstar nocaseglob nullglob

for f in **/AGENTS.md; do
  [ -L "$f" ] && continue
  (
    cd "$(dirname "$f")"

    echo '<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->' > AGENTS.md

    for md in *.md; do
      if [ -f "$md" ] && [ ! -L "$md" ] && [ "${md,,}" != "agents.md" ]; then
        # Find max heading depth
        max_depth=$(awk '
          /^ *```/ { in_code = !in_code; next }
          !in_code && /^ *#/ {
            sub(/^ */, "")
            match($0, /^#+/)
            if (RLENGTH > max) max = RLENGTH
          }
          END { print max+0 }
        ' "$md")

        # Output file heading and extracted headings
        {
          echo
          title="$(printf '%s' "${md%.md}" | tr -cs 'a-zA-Z' ' ')"
          echo "# $title"
          awk -v max_depth="$max_depth" '
            /^ *```/ { in_code = !in_code; next }
            !in_code && /^ *#/ {
              sub(/^ */, "")
              match($0, /^#+/)
              n = RLENGTH
              sub(/^#+ */, "")

              if (n == max_depth) {
                print "- " $0
              } else {
                prefix = ""
                for (i = 0; i <= n; i++) prefix = prefix "#"
                print prefix " " $0
              }
            }
          ' "$md"
        } >> AGENTS.md
      fi
    done
  )
done
