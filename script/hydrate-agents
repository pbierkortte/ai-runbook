#!/bin/bash
set -euo pipefail
shopt -s globstar nocaseglob nullglob dotglob

cd "$(git rev-parse --show-toplevel)"

for f in **/AGENTS.md; do
  [[ -L "$f" ]] && continue
  (
    cd "$(dirname "$f")"
    echo '<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->' > AGENTS.md
    for md in *.md; do
      [[ -f "$md" && ! -L "$md" && "${md,,}" != 'agents.md' ]] || continue
      {
        echo
        title="$(printf '%s' "${md%.md}" | tr -cs 'a-zA-Z' ' ')"
        echo "# $title"
        awk '
          BEGIN { n = 0; in_code = 0 }
          /^ *```/ { in_code = !in_code; next }
          !in_code && /^ *#/ {
            sub(/^ */, "")
            match($0, /^#+/)
            depth[n] = RLENGTH
            line = $0
            sub(/^#+ */, "", line)
            text[n] = line
            n++
          }
          END {
            for (i = 0; i < n; i++) {
              is_leaf = (i == n - 1) || (depth[i + 1] <= depth[i])
              if (is_leaf) {
                print "* " text[i]
              } else {
                prefix = ""
                for (j = 0; j <= depth[i]; j++) prefix = prefix "#"
                print prefix " " text[i]
              }
            }
          }
        ' "$md"
      } >> AGENTS.md
    done
  )
done
