#!/bin/bash
set -eo pipefail
shopt -s globstar nocaseglob nullglob dotglob

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0 2>/dev/null || exit 0
cd "$(git rev-parse --show-toplevel)"

[[ -f AGENTS.md ]] || return 0 2>/dev/null || exit 0

for f in **/AGENTS.md; do
  [[ -L "$f" ]] && continue
  dir="$(dirname "$f")"
  {
    echo '<!-- DO NOT EDIT THIS FILE IS AUTOMATICALLY GENERATED -->'
    for rules in "$dir"/*_RULES.md; do
      [[ -f "$rules" ]] || continue
      echo
      cat "$rules"
    done
    manifest="$dir/MANIFEST.md"
    if [[ -f "$manifest" ]]; then
      # strip the auto-generated header line from MANIFEST.md before appending
      tail -n +2 "$manifest"
    fi
  } > "$f"
done
